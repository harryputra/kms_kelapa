# ---- Database (MySQL) ----
DATABASE_URL="mysql://root:coconexus@127.0.0.1:33062/coconexus"

# ---- Server ----
PORT=3000
NODE_ENV=development
# Origin frontend yang diizinkan (CORS). Pisahkan dengan koma bila lebih dari satu.
CORS_ORIGIN="http://localhost:5173,http://localhost:4173"

# ---- Auth (WAJIB diganti di produksi!) ----
JWT_ACCESS_SECRET="dev-access-secret-ganti-di-produksi"
JWT_REFRESH_SECRET="dev-refresh-secret-ganti-di-produksi"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=7

# ---- Akun admin esensial (dipakai seeder produksi) ----
ADMIN_EMAIL="admin@coconexus.test"
ADMIN_PASSWORD="Admin#1234"

# Seed data demo (true hanya untuk demo/dev)
SEED_DEMO=true

# ---- Asisten AI "Tanya COCO" (RAG) — opsional pre-configure ----
# Bisa juga diatur lewat UI admin (/admin/ai). Nilai di sini hanya di-seed
# saat key belum ada (tidak menimpa pengaturan dari UI).
# Provider: "openai" (OpenAI-compatible: OpenAI/OpenRouter/Groq/Ollama/OpenWebUI/LM Studio) atau "anthropic".
AI_ENABLED=false
AI_PROVIDER=openai
# Ollama lokal di host (saat API jalan di Docker): http://host.docker.internal:11434/v1
# Ollama langsung di host (API non-docker): http://localhost:11434/v1
# OpenWebUI: http://host:3000/api   ·   OpenAI: https://api.openai.com/v1
AI_BASE_URL=http://host.docker.internal:11434/v1
AI_MODEL=qwen2.5:3b
# Ollama lokal umumnya tak perlu key. OpenWebUI/OpenAI/Anthropic: isi key.
AI_API_KEY=
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=700
AI_TOP_K=4
