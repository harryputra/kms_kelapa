# Base URL API — relatif same-origin. JANGAN hardcode http://localhost:PORT.
# Backend mengekspos /api/v1 (proxy vite & reverse-proxy meneruskan same-origin).
VITE_API_URL=/api/v1

# Gunakan mock API in-memory (true) saat backend belum siap.
# Set "false" untuk memakai backend nyata via VITE_API_URL.
VITE_USE_MOCK=true

# Nama aplikasi (opsional)
VITE_APP_NAME=COCONEXUS

# Target proxy /api saat backend nyata berjalan (dipakai vite.config saja, bukan kode app)
VITE_API_PROXY_TARGET=http://localhost:3000
