{
  "name": "coconexus-kms",
  "private": true,
  "version": "2.0.0",
  "description": "COCONEXUS KMS v2.0 — Platform Manajemen Pengetahuan Limbah Kelapa untuk UMKM",
  "scripts": {
    "dev": "pnpm --filter @coconexus/web dev",
    "dev:web": "pnpm --filter @coconexus/web dev",
    "dev:api": "pnpm --filter @coconexus/api dev",
    "build": "pnpm -r build",
    "preview": "pnpm --filter @coconexus/web preview",
    "typecheck": "pnpm -r typecheck",
    "qa:crawl": "node scripts/crawl.mjs",
    "db:up": "docker compose -f infra/docker-compose.yml up -d mysql",
    "db:down": "docker compose -f infra/docker-compose.yml down",
    "db:push": "pnpm --filter @coconexus/api db:push",
    "db:seed": "pnpm --filter @coconexus/api db:seed",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "puppeteer-core": "^23.11.1"
  }
}
